install() {
    local \
        packages_to_install \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list packages flag"
                    exit 1
                }
                FLAG_list_packages=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                packages_to_install+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_packages))
    then
        printf "\nPackages Available to Install:\n"
        for package_name in $INSTALLABLE_PACKAGES
        do
            echo "  - $package_name"
        done
        
        if [[ -n $packages_to_install ]]
        then
            printf "\n\e[31m%s %s\e[0m\n" \
                "[!] Cannot list installable packages" \
                "and install packages in the same command"
            exit 1
        fi

        exit 0
    fi

    for package_name in ${packages_to_install[@]}
    do
        if ! echo "$INSTALLABLE_PACKAGES" | grep "$package_name" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] '$package_name' is not a supported package" \
                " - TIP: run \`arch install --list\` to see supported packages"
            exit 2
        fi
    done

    if check_library_files_exist
    then
        source ./$PACKAGE_INSTALLATION_LIBRARY
    else
        printf "\n\e[31m%s\n%s\e[0m\n" \
            "[!] Issue sourcing package installation library despite passing" \
            "    library file checks... This shouldn't happen"
    fi

    for package_name in ${packages_to_install[@]}
    do
        case $package_name in
            "yay")
                if ! install_yay
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install yay"
                fi
            ;;
            "qutebrowser")
                if ! install_qutebrowser
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install qutebrowser"
                fi
            ;;
            "librewolf")
                if ! install_librewolf
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install librewolf"
                fi
            ;;
            "docker")
                if ! install_docker
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install docker"
                fi
            ;;
            "python")
                if ! install_python
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install python"
                fi
            ;;
            "rust")
                if ! install_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install rust"
                fi
            ;;
            "flatpak")
                if ! install_flatpak
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install flatpak"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen packages did not match installation case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

uninstall() {
    local \
        packages_to_uninstall \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list installed packages flag"
                    exit 1
                }
                FLAG_list_packages=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                packages_to_uninstall+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_packages))
    then
        printf "\nInstalled Packages:\n"
        for package_name in $INSTALLABLE_PACKAGES
        do
            if ! { which yay || type yay; } &>/dev/null
            then
                if yay -Q $package_name &>/dev/null
                then
                    echo "  - $package_name"
                fi
            else
                if pacman -Q $package_name &>/dev/null
                then
                    echo "  - $package_name"
                fi
            fi
        done
        
        if [[ -n $packages_to_uninstall ]]
        then
            printf "\n\e[31m%s\e[0m" \
                "[!] Cannot list and uninstall packages in the same command"
            exit 1
        fi

        exit 0
    fi

    for package_name in ${packages_to_uninstall[@]}
    do
        if ! echo "$INSTALLABLE_PACKAGES" | grep "$package_name" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] '$package_name' is not a supported package" \
                " - TIP: run \`arch uninstall --list\` to see supported packages"
            exit 3
        fi


        if ! { which yay || type yay; } &>/dev/null
        then
            if ! yay -Q $package_name &>/dev/null
            then
                printf "\n\e[31m%s\n%s %s\e[0m\n" \
                    "[!] '$package_name' is not installed" \
                    " - TIP: run \`arch uninstall --list\` to see" \
                    "installed packages"
                exit 3
            fi
        fi

        if ! pacman -Q $package_name &>/dev/null
        then
            echo -e "\n'$package_name' is not installed"
            echo -e "\nTIP: run \`arch uninstall --list\` to see installed packages"
            exit 3
        fi
    done

    if check_library_files_exist
    then
        source ./$PACKAGE_INSTALLATION_LIBRARY
    else
        printf "\n\e[31m%s\n%s\e[0m\n" \
            "[!] Issue sourcing package installation library despite passing" \
            "    library file checks... This shouldn't happen"
    fi

    for package_name in ${packages_to_uninstall[@]}
    do
        case $package_name in
            "yay")
                if ! uninstall_yay
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall yay"
                fi
            ;;
            "qutebrowser")
                if ! uninstall_qutebrowser
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall qutebrowser"
                fi
            ;;
            "librewolf")
                if ! uninstall_librewolf
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall librewolf"
                fi
            ;;
            "docker")
                if ! uninstall_docker
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall docker"
                fi
            ;;
            "python")
                if ! uninstall_python
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall python"
                fi
            ;;
            "rust")
                if ! uninstall_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall rust"
                fi
            ;;
            "flatpak")
                if ! uninstall_flatpak
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall flatpak"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen packages did not match uninstall case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

setup() {
    local \
        setups_chosen \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list setups flag"
                    exit 1
                }
                FLAG_list_setups=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                setups_chosen+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_setups))
    then
        printf "\nAvailable Setup Options:\n"
        for setup_name in $SETUP_OPTIONS
        do
            echo "  - $setup_name"
        done

        if [[ -n $setups_chosen ]]
        then
            printf "\n\e[31m%s %s\e[0m\n" \
                "[!] Cannot list setup options and" \
                "set them up in the same command"
        fi

        exit 0
    fi

    for setup_name in ${setups_chosen[@]}
    do
        if ! echo "$SETUP_OPTIONS" | grep "$setup_name" &>/dev/null
        then
            printf "\n\n\e[31m%s\n\t%s\e[0m\n" \
                "[!] '$setup_name' is not a supported setup" \
                " - TIP: run \`arch setup --list\` to see supported setups"
