#
# CLI tool to replace Arch-Setup and Arch-Configurations. It will
#  make the process of installing software and having them automatically
#  configured to my setup much easier.
#

SCRIPT_NAME="arch"

REQUIRED_PACKAGES=( \
    bash pacman \
    usermod gpasswd groups \
    grep cat \
)

INSTALLABLE_PACKAGES="\
    yay qutebrowser librewolf docker rust python \
"
SETUP_OPTIONS="\
    security user-scripts audio bluetooth \
    river gnome dwm dwl \
    gaming media qemu \
    embedded dioxus \
"

PACKAGE_INSTALLATION_LIBRARY=package_installation_library.sh
SETUP_INSTALLATION_LIBRARY=setup_installation_library.sh

PRETTY_OUTPUT_LIBRARY=pretty_output_library.sh

check_library_files_exist() {
    if ! [[ -f "./$PRETTY_OUTPUT_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing pretty output script. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "./$PACKAGE_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing package installation scripts. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "./$SETUP_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing setup installation scripts. Cannot Proceed"
        exit 4
    fi
}

check_packages()
{
    for tool in ${REQUIRED_PACKAGES[@]}
    do
        if ! { which $tool || type $tool; } &>/dev/null
        then
            printf "\n\e[31m%s\e[0m\n" "[!] Must install '$tool' for $SCRIPT_NAME to work"
            tools_not_installed=1
        fi
    done

    if ((tools_not_installed))
    then
        exit 6
    fi
}

display_help() {
    printf "\nUsage: $SCRIPT_NAME [COMMAND]"
    printf "\n\n  %s\n  %s" \
        "Simplifies Arch-Setup and Arch-Configurations into a single" \
        "CLI tool with many more automated features."

    printf "\n\nCommands:"
    printf "\n  %-15s %-1s" "install" "Install supported software"
    printf "\n  %-15s %-1s" "uninstall" "Cleanly uninstall supported software"
    printf "\n  %-15s %-1s" "setup" "Setup the system in specific ways"
    printf "\n  %-15s %-1s" "remove-setup" "Remove a setup"
    printf "\n  %-15s %-1s" "version" "Returns version information"

    printf "\n\n%s" \
        "(\`install\` is for tools you use directly: rust, docker, qutebrowser)"
    printf "\n%s" \
        "(\`setup\` is for set it and forget it defaults: security, river, bluetooth)"

    printf "\n\nBase Flags:"
    printf "\n  %-20s %-1s" "--version" "Returns version information"
    printf "\n  %-20s %-1s" "-h | --help" "Show this help message"

    printf "\n\nCommand Flags:"
    printf "\n  install:"
    printf "\n    %-20s %-1s" "-l | --list" "List installable software"
    printf "\n  uninstall:"
    printf "\n    %-20s %-1s" "-l | --list" "List installed software"
    printf "\n  setup:"
    printf "\n    %-20s %-1s" "-l | --list" "List available setup options"
    
    printf "\n\nExamples:"
    printf "\n  \`$SCRIPT_NAME install --list\`"
    printf "\n  \`$SCRIPT_NAME uninstall --list\`"
    printf "\n  \`$SCRIPT_NAME install qutebrowser\`"
    printf "\n  \`$SCRIPT_NAME install rust qemu docker\`"
    printf "\n  \`$SCRIPT_NAME uninstall qutebrowser\`"
    printf "\n  \`$SCRIPT_NAME setup river bluetooth\`"
    printf "\n  \`$SCRIPT_NAME setup security user-scripts\`"
    printf "\n  \`$SCRIPT_NAME remove-setup rust\`"

    printf "\n\nError Codes:"
    printf "\n  %-3s %-1s" "1" "Invalid command"
    printf "\n  %-3s %-1s" "2" "Package, setup, or preset doesn't exist"
    printf "\n  %-3s %-1s\n      %s" "3" \
        "Can't be uninstalled or removed as it doesn't exist or" \
        "isn't installed"
    printf "\n  %-3s %-1s" "4" "Missing source file for $SCRIPT_NAME"
    printf "\n  %-3s %-1s\n      %s" "5" \
        "Package, setup, or preset depends on one or many other" \
        "$SCRIPT_NAME commands being run first"
    printf "\n  %-3s %-1s" "6" "Missing package required by script"
}

install() {
    local \
        packages_to_install \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list packages flag"
                    exit 1
                }
                FLAG_list_packages=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                packages_to_install+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_packages))
    then
        printf "\nPackages Available to Install:\n"
        for package_name in $INSTALLABLE_PACKAGES
        do
            echo "  - $package_name"
        done
        
        if [[ -n $packages_to_install ]]
        then
            printf "\n\e[31m%s %s\e[0m\n" \
                "[!] Cannot list installable packages" \
                "and install packages in the same command"
            exit 1
        fi

        exit 0
    fi

    for package_name in ${packages_to_install[@]}
    do
        if ! echo "$INSTALLABLE_PACKAGES" | grep "$package_name" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] '$package_name' is not a supported package" \
                " - TIP: run \`arch install --list\` to see supported packages"
            exit 2
        fi
    done

    source ./$PACKAGE_INSTALLATION_LIBRARY || check_library_files_exist

    for package_name in ${packages_to_install[@]}
    do
        case $package_name in
            "yay")
                if ! install_yay
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install yay"
                fi
            ;;
            "qutebrowser")
                if ! install_qutebrowser
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install qutebrowser"
                fi
            ;;
            "librewolf")
                if ! install_librewolf
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install librewolf"
                fi
            ;;
            "docker")
                if ! install_docker
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install docker"
                fi
            ;;
            "python")
                if ! install_python
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install python"
                fi
            ;;
            "rust")
                if ! install_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to install rust"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen packages did not match installation case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

uninstall() {
    local \
        packages_to_uninstall \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list installed packages flag"
                    exit 1
                }
                FLAG_list_packages=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                packages_to_uninstall+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_packages))
    then
        printf "\nInstalled Packages:\n"
        for package_name in $INSTALLABLE_PACKAGES
        do
            if ! { which yay || type yay; } &>/dev/null
            then
                if yay -Q $package_name &>/dev/null
                then
                    echo "  - $package_name"
                fi
            else
                if pacman -Q $package_name &>/dev/null
                then
                    echo "  - $package_name"
                fi
            fi
        done
        
        if [[ -n $packages_to_uninstall ]]
        then
            printf "\n\e[31m%s\e[0m" \
                "[!] Cannot list and uninstall packages in the same command"
            exit 1
        fi

        exit 0
    fi

    for package_name in ${packages_to_uninstall[@]}
    do
        if ! echo "$INSTALLABLE_PACKAGES" | grep "$package_name" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] '$package_name' is not a supported package" \
                " - TIP: run \`arch uninstall --list\` to see supported packages"
            exit 3
        fi


        if ! { which yay || type yay; } &>/dev/null
        then
            if ! yay -Q $package_name &>/dev/null
            then
                printf "\n\e[31m%s\n%s %s\e[0m\n" \
                    "[!] '$package_name' is not installed" \
                    " - TIP: run \`arch uninstall --list\` to see" \
                    "installed packages"
                exit 3
            fi
        fi

        if ! pacman -Q $package_name &>/dev/null
        then
            echo -e "\n'$package_name' is not installed"
            echo -e "\nTIP: run \`arch uninstall --list\` to see installed packages"
            exit 3
        fi
    done

    source ./$PACKAGE_INSTALLATION_LIBRARY || check_library_files_exist

    for package_name in ${packages_to_uninstall[@]}
    do
        case $package_name in
            "yay")
                if ! uninstall_yay
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall yay"
                fi
            ;;
            "qutebrowser")
                if ! uninstall_qutebrowser
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall qutebrowser"
                fi
            ;;
            "librewolf")
                if ! uninstall_librewolf
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall librewolf"
                fi
            ;;
            "docker")
                if ! uninstall_docker
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall docker"
                fi
            ;;
            "python")
                if ! uninstall_python
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall python"
                fi
            ;;
            "rust")
                if ! uninstall_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to uninstall rust"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen packages did not match uninstall case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

setup() {
    local \
        setups_chosen \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list setups flag"
                    exit 1
                }
                FLAG_list_setups=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                setups_chosen+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_setups))
    then
        printf "\nAvailable Setup Options:"
        for setup_name in $SETUP_OPTIONS
        do
            echo "  - $setup_name"
        done

        if [[ -n $setups_chosen ]]
        then
            printf "\n\e[31m%s %s\e[0m\n" \
                "[!] Cannot list setup options and" \
                "set them up in the same command"
        fi

        exit 0
    fi

    for setup_name in ${setups_chosen[@]}
    do
        if ! echo "$SETUP_OPTIONS" | grep "$setup_name" &>/dev/null
        then
            printf "\n\n\e[31m%s\n\t%s\e[0m\n" \
                "[!] '$setup_name' is not a supported setup" \
                " - TIP: run \`arch setup --list\` to see supported setups"
            exit 2
        fi
    done

    source ./$SETUP_INSTALLATION_LIBRARY || check_library_files_exist

    for setup_name in ${setups_chosen[@]}
    do
        case $package_name in
            "qemu")
                if ! setup_qemu
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to setup qemu"
                fi
            ;;
            *)
                printf "\e[31m%s %s\e[0m" \
                    "Chosen setups did not match setup case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

remove_setup() {
    local \
        setups_chosen \

    for arg in $@
    do
        case $arg in
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                setups_chosen+=($arg)
            ;;
        esac
    done

    for setup_name in ${setups_chosen[@]}
    do
        if ! echo "$SETUP_OPTIONS" | grep "$setup_name" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] '$setup_name' is not a supported setup option" \
                " - TIP: run \`arch setup --list\` to see supported setup options"
            exit 3
        fi
    done

    source ./$PACKAGE_INSTALLATION_LIBRARY || check_library_files_exist

    for setup_name in ${setups_chosen[@]}
    do
        case $setup_name in
            "qemu")
                if ! remove_setup_qemu
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: qemu"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen setup did not match remove setup case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

check_packages
check_library_files_exist

case $1 in
    "install")      install ${@:2};;
    "uninstall")    uninstall ${@:2};;
    "setup")        setup ${@:2};;
    "remove-setup")      remove_setup ${@:2};;
    "version"|"--version") echo "0.1.0";;
    "--help"|"-h") display_help;;
    *) 
        printf "\n\n - [ERROR] Invalid use of the \`arch\` command -";
        display_help
        exit 1
        ;;
esac
