                if ! remove_setup_embedded_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: embedded-rust"
                fi
            ;;
            "rust-dioxus")
                if ! remove_setup_rust_dioxus
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: rust-dioxus"
                fi
            ;;
            "3d-printing")
                if ! remove_setup_3d_printing
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: 3d-printing"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen setup did not match remove setup case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

case $1 in
    "add-to-path")         add_to_path ${@:2};exit ;exit 00;;
esac

cd $arch_setup_directory

check_packages
check_library_files_exist

case $1 in
    "install")             install ${@:2};bash ./$CONFIG_INSTALL_SCRIPT;;
    "uninstall")           uninstall ${@:2};bash ./$CONFIG_INSTALL_SCRIPT;;
    "setup")               setup ${@:2};bash ./$CONFIG_INSTALL_SCRIPT;;
    "remove-setup")        remove_setup ${@:2};bash ./$CONFIG_INSTALL_SCRIPT;;
    "add-configs")         bash ./$CONFIG_INSTALL_SCRIPT;;
    "version"|"--version") echo "0.1.0";;
    "--help"|"-h") display_help;;
    *) 
        printf "\n\n - [ERROR] Invalid use of the \`$SCRIPT_NAME\` command -";
        display_help
        exit 1
        ;;
esac


