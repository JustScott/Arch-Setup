#
# CLI tool to replace Arch-Setup and Arch-Configurations. It will
#  make the process of installing software and having them automatically
#  configured to my setup much easier.
#

# TODO: remove-setup, how to know whether to remove packages or not?
#   - for example, if the user setups gaming, and flatpak is installed,
#     how do I know they haven't started using flatpak now?

PROJECT_NAME="Arch-Setup"
SCRIPT_NAME="arch"

REQUIRED_PACKAGES=( \
    bash pacman \
    usermod gpasswd groups groupadd groupdel \
    grep cat \
    rfkill command \
)

INSTALLABLE_PACKAGES="\
    yay qutebrowser librewolf docker rust python flatpak \
"
SETUP_OPTIONS="\
    security user-scripts audio bluetooth \
    river gnome dwm dwl \
    gaming media qemu 3d-printing \
    embedded-rust rust-dioxus \
"

PACKAGE_INSTALLATION_LIBRARY=package_installation_library.sh
SETUP_INSTALLATION_LIBRARY=setup_installation_library.sh

PRETTY_OUTPUT_LIBRARY=pretty_output_library.sh

CONFIG_INSTALL_SCRIPT=install_configurations.sh

if ! echo "$@" | grep "add-to-path" &>/dev/null
then
    if ! [[ -d $arch_setup_directory ]]
    then
        printf "\n\e[31m%s\n%s\n%s\e[0m\n" \
            "[!] '\$arch_setup_directory' variable not set, or not set to" \
            "    the correct directory path. Either way, \`cd\` into the" \
            "    '$PROJECT_NAME' directory and run \`$SCRIPT_NAME add-to-path\`."
        exit $4
    fi
fi

add_to_path() {
    if [[ $(basename $(pwd)) == "$PROJECT_NAME" ]]
    then
        bashrc_line="export arch_setup_directory=\"$(pwd)\""

        if ! [[ -f "$HOME/.bashrc" ]]
        then
            if touch $HOME/.bashrc &>/dev/null
            then
                printf "\n\e[32m%s\e[0m\n" \
                    "Created the file $HOME/.bashrc"
            else
                printf "\n\e[31m%s\n%s\n%s\e[0m\n" \
                    "[!] Your user doesn't have a .bashrc in there \$HOME" \
                    "    directory, and attempts at creating one failed. A" \
                    "    $HOME/.bashrc file is required for this script."
                exit 7
            fi
        fi

        if grep "export arch_setup_directory=\"" $HOME/.bashrc \
            | grep "/$PROJECT_NAME\"$" &>/dev/null
        then
            # Replace existing variable with this new one
            sed -i \
                's,export arch_setup_directory=".*\/Arch-Setup"$,'"$bashrc_line"',' \
                $HOME/.bashrc
        else
            echo -e "\n$bashrc_line" >> $HOME/.bashrc
        fi

        # Check that the line was added without issue
        if grep "$bashrc_line" $HOME/.bashrc &>/dev/null
        then
            printf "\n\e[32m%s\e[0m\n" \
                "Added '$PROJECT_NAME' directory path to '.bashrc'"
        else
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] Could not add '$PROJECT_NAME' directory to your" \
                "    '.bashrc'... Check the files permissions and try again"
            exit 7
        fi

        # Create a .bin directory in $HOME for the arch script
        if ! [[ -f "./$SCRIPT_NAME" ]]
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] './$SCRIPT_NAME' not found. Move to the '$PROJECT_NAME'" \
                "    directory containing the '$SCRIPT_NAME' script and try again"
            exit 8
        fi

        chmod u+x "./$SCRIPT_NAME"

        if ! [[ -d $HOME/.bin ]]
        then
            printf "\n\e[33m%s\e[0m" "[!] $HOME/.bin directory doesn't exit"

            if mkdir -p $HOME/.bin &>/dev/null
            then
                printf "\n\e[32m%s\e[0m" "Created $HOME/.bin"
            else
                printf "\n\e[31m%s\e[0m\n" "[!] Failed to create $HOME/.bin"
                exit 7
            fi
        fi

        if ! [[ -L "$HOME/.bin/$SCRIPT_NAME" ]]
        then
            if ln -s "$(pwd)/$SCRIPT_NAME" $HOME/.bin/ &>/dev/null
            then
                printf "\n\e[32m%s\e[0m\n" \
                    "Created softlink to '$SCRIPT_NAME' in $HOME/.bin"
            else
                printf "\n\e[31m%s\e[0m\n" \
                    "[!] Failed to create softlink to '$SCRIPT_NAME' in $HOME/.bin"
                exit 7
            fi
        fi

        path_modification="export PATH=\"\$PATH:$HOME/.bin\""

        if ! grep "^$path_modification$" $HOME/.bashrc &>/dev/null
        then
            echo -e "\n$path_modification" >> $HOME/.bashrc
        fi

        # Check that the line was added without issue
        if ! grep "$path_modification" $HOME/.bashrc &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] Could not edit path in '$HOME/.bashrc'..." \
                "    Check the files permissions and try again"
            exit 7
        fi
    else
        printf "\n\e[31m%s %s\e[0m\n" \
            "[!] Must be in the $PROJECT_NAME directory to" \
            "add it's path to your .bashrc"
        exit 1
    fi
}

check_library_files_exist() {
    if ! [[ -f "./$PRETTY_OUTPUT_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing pretty output script. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "./$PACKAGE_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing package installation scripts. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "./$SETUP_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing setup installation scripts. Cannot Proceed"
        exit 4
    fi
}

check_packages()
{
    for tool in ${REQUIRED_PACKAGES[@]}
    do
        if ! { which $tool || type $tool; } &>/dev/null
        then
            printf "\n\e[31m%s\e[0m\n" "[!] Must install '$tool' for $SCRIPT_NAME to work"
            tools_not_installed=1
        fi
    done

    if ((tools_not_installed))
    then
        exit 6
    fi
}

